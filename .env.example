# Cadena de conexión a MySQL
DATABASE_URL="mysql://usuario:contraseña@localhost:3306/nombre_base_datos"

# Clave secreta para JWT (generar una nueva para cada entorno)
JWT_SECRET="tu_clave_secreta_super_larga_y_segura_aqui"
 
# Puerto donde correrá el servidor
PORT=3000

# --- Sincronización de usuarios hacia Gestión de Flota (localhost) ---
# URL del webhook (sync en tiempo real y cron diario 02:00 usan la misma ruta)
FLOTA_WEBHOOK_SYNC_URL=http://127.0.0.1:3004/api/webhooks/usuarios/sync
# Mismo valor exacto que WEBHOOK_SYNC_SECRET en el backend de Flota
FLOTA_WEBHOOK_SYNC_SECRET=
# Opcional: false desactiva solo el cron diario de sincronización masiva
# FLOTA_SYNC_CRON_ENABLED=true
